/* ============================================================
 *  メイン: 全シート一括反映
 * ============================================================ */
function syncAllSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const t0 = new Date();
  syncSheet_(ss, SHEET_PRIORITY, DATA, '営業優先シート');
  // タスク管理は P列(LP URL) が https で始まる社のみ
  const taskRows = DATA.filter(r => typeof r[15] === 'string' && r[15].indexOf('https://') === 0);
  syncSheet_(ss, SHEET_TASK, taskRows, 'タスク管理シート');
  const sec = ((new Date() - t0) / 1000).toFixed(1);
  SpreadsheetApp.getUi().alert(
    `✅ 完了\n\n` +
    `営業優先シート: ${DATA.length} 社\n` +
    `タスク管理シート: ${taskRows.length} 社（LP URLあり）\n` +
    `処理時間: ${sec} 秒`
  );
}

