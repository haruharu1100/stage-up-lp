# ──── Google Sheets ────
SHEETS_ID=
# GA4と同じサービスアカウントを流用可能
SHEETS_SERVICE_ACCOUNT_JSON=

# ──── Notification (Email) ────
NOTIFY_EMAIL_TO=hatunemikudaisuki@gmail.com
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_SMTP_HOST=smtp.gmail.com
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_SMTP_USER=
NOTIFY_EMAIL_SMTP_PASS=

# ──── Mode (DEV / PRODUCTION) ────
RUN_MODE=DEV
DRY_RUN=true
