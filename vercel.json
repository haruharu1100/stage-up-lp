{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/api/auth?slug=admin" },
    { "source": "/:slug(\\d+-[a-z0-9-]+)", "destination": "/api/auth?slug=:slug" },
    { "source": "/:slug(m\\d+-[a-z0-9-]+)", "destination": "/api/auth?slug=:slug" },
    { "source": "/a/:slug", "destination": "/affiliate/lp/:slug" }
  ],
  "redirects": [
    { "source": "/_proposals/:path*", "destination": "/", "permanent": false }
  ],
  "functions": {
    "api/auth.js": {
      "includeFiles": "_proposals/**"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
