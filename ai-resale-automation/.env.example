# ============================================================
# AI物販自動化システム 環境変数サンプル
# ------------------------------------------------------------
# 使い方:
#   1. このファイルをコピーして「.env」という名前にする
#        Windows : copy .env.example .env
#        Mac/Linux: cp .env.example .env
#   2. 下の値を自分のものに書き換える
#   3. .env ファイルは絶対に他人に渡さない / GitHubに上げない
# ============================================================

# ------------------------------------------------------------
# Claude API(必須:AIタイトル・説明文の生成に使用)
# ------------------------------------------------------------
# Anthropicの管理画面 https://console.anthropic.com/ で発行したキーを貼る
# 例: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=ここにAPIキーを貼る

# 使用するモデル(そのままでOK)
#   品質重視 : claude-sonnet-4-6
#   安さ重視 : claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# 利益・判定のしきい値(必要なら変更可)
# ------------------------------------------------------------
# 出品候補にする最低の利益率(%)
MIN_PROFIT_RATE=25

# 出品候補にする最低の過去1ヶ月販売数(個)
MIN_MONTHLY_SALES=1

# 出品候補にする最低の在庫数(個)
MIN_STOCK=1

# ------------------------------------------------------------
# AI生成の動作設定
# ------------------------------------------------------------
# AIを使わずにテンプレート文章で動かす場合は true にする
#   true  : Claude APIを呼ばない(キー不要・無料でお試し可能)
#   false : Claude APIを呼んで本物のAI文章を作る
USE_AI_OFFLINE_MODE=false

# AI文章を作る対象の判定。カンマ区切り。
# 通常は「出品候補」と「要確認」だけ作れば十分(APIコスト節約)
AI_TARGET_JUDGMENTS=出品候補,要確認

# ------------------------------------------------------------
# Googleスプレッドシート連携(任意:使わない場合は空でOK)
# ------------------------------------------------------------
# サービスアカウントのJSONファイルへのパス
# (READMEの「スプレッドシート連携」を参照)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# 書き込み先スプレッドシートのID
# URLの https://docs.google.com/spreadsheets/d/【ここがID】/edit の部分
GOOGLE_SPREADSHEET_ID=

# 書き込み先のシート名(タブの名前)
GOOGLE_WORKSHEET_NAME=出品候補
